  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.3",
    "antd": "^5.27.3",
    "axios": "^1.13.4",
    "clsx": "^2.1.1",
    "formik": "^2.4.9",
    "framer-motion": "^12.33.0",
    "next": "^15.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-redux": "^9.1.2",
    "react-router-dom": "^7.13.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  }
}
